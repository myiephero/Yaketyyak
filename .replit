modules = ["python-3.11", "javascript", "nodejs-20", "python3"]
[deployment]
deploymentTarget = "autoscale"
run = ["streamlit", "run", "app.py", "--server.port", "5000"]

[nix]
channel = "stable-25_05"

[agent]
integrations = ["python_openai_ai_integrations:1.0.0", "github:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "TUI Preview"

[[workflows.workflow]]
name = "TUI Preview"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python serve_tui.py"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 5000
